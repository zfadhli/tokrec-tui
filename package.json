{
  "name": "tokrec-tui",
  "version": "0.3.1",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "tsdown && chmod +x bin/tokrec-tui",
    "link": "bun run build && bun link",
    "lint": "bunx biome check src/",
    "format": "bunx biome format --write src/"
  },
  "bin": {
    "tokrec-tui": "./bin/tokrec-tui"
  },
  "dependencies": {
    "@opentui/core": "^0.4.3",
    "@zfadhli/tokrec": "^0.12.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "latest",
    "lefthook": "^2.1.9",
    "tsdown": "^0.22.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
